# Copy to .env and fill in.

# Secret required on every /api/* call (except /api/health).
# Generate with e.g.  [guid]::NewGuid().ToString("N")   in PowerShell.
APP_SECRET=change-me-to-a-long-random-string

# Cloudflare Tunnel token.
# Create a named tunnel in the CF dashboard, route verified.craftbeers.app
# to http://venue_list:5175 (the docker-compose service name + port),
# then copy the connector token here.
TUNNEL_TOKEN=
